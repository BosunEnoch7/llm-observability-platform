APP_ENV=development
LOG_LEVEL=INFO
LLM_PROVIDER=simulated
DEFAULT_MODEL=demo-model
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.25
INPUT_PRICE_PER_MILLION_TOKENS=1.00
OUTPUT_PRICE_PER_MILLION_TOKENS=2.00
SIMULATED_FAILURE_RATE=0.00
SIMULATED_MIN_LATENCY_MS=100
SIMULATED_MAX_LATENCY_MS=500

# Azure OpenAI (required only when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_USE_MANAGED_IDENTITY=true
# Local fallback only. Prefer managed identity in Azure.
AZURE_OPENAI_API_KEY=
