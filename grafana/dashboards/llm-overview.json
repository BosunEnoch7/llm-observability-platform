{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat", "title": "Request rate", "id": 1,
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(llm_http_requests_total{route=\"/v1/generate\"}[5m]))", "legendFormat": "requests/s"}]
    },
    {
      "type": "stat", "title": "Success rate", "id": 2,
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "targets": [{"expr": "sum(rate(llm_http_requests_total{route=\"/v1/generate\",status_code=~\"2..\"}[5m])) / clamp_min(sum(rate(llm_http_requests_total{route=\"/v1/generate\"}[5m])), 0.001)", "legendFormat": "success"}]
    },
    {
      "type": "stat", "title": "P95 inference latency", "id": 3,
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(llm_inference_duration_seconds_bucket[5m])))", "legendFormat": "p95"}]
    },
    {
      "type": "stat", "title": "Estimated cost", "id": 4,
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "targets": [{"expr": "sum(llm_estimated_cost_usd_total)", "legendFormat": "USD"}]
    },
    {
      "type": "timeseries", "title": "Requests by status", "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [{"expr": "sum by (status_code) (rate(llm_http_requests_total{route=\"/v1/generate\"}[5m]))", "legendFormat": "HTTP {{status_code}}"}]
    },
    {
      "type": "timeseries", "title": "Token usage", "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [{"expr": "sum by (model, direction) (rate(llm_tokens_total[5m]))", "legendFormat": "{{model}} {{direction}}"}]
    },
    {
      "type": "stat", "title": "Availability SLO (30m)", "id": 7,
      "gridPos": {"h": 7, "w": 6, "x": 0, "y": 14},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 0.99}]}}},
      "targets": [{"expr": "llm:slo_availability:ratio_rate30m", "legendFormat": "availability"}]
    },
    {
      "type": "timeseries", "title": "Availability error-budget burn rate", "id": 8,
      "gridPos": {"h": 7, "w": 18, "x": 6, "y": 14},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"expr": "llm:slo_error_budget:burn_rate5m", "legendFormat": "5m burn"},
        {"expr": "llm:slo_error_budget:burn_rate1h", "legendFormat": "1h burn"},
        {"expr": "vector(14.4)", "legendFormat": "fast threshold"}
      ]
    },
    {
      "type": "timeseries", "title": "Provider attempts", "id": 9,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "targets": [{"expr": "sum by (provider, outcome) (rate(llm_provider_attempts_total[5m]))", "legendFormat": "{{provider}} {{outcome}}"}]
    },
    {
      "type": "timeseries", "title": "Provider retries", "id": 10,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "targets": [{"expr": "sum by (provider) (rate(llm_provider_retries_total[5m]))", "legendFormat": "{{provider}}"}]
    },
    {
      "type": "stat", "title": "Average quality rating", "id": 11,
      "gridPos": {"h": 7, "w": 6, "x": 0, "y": 29},
      "fieldConfig": {"defaults": {"unit": "short", "min": 1, "max": 5}},
      "targets": [{"expr": "sum(rate(llm_quality_rating_sum[15m])) / clamp_min(sum(rate(llm_quality_rating_count[15m])), 0.000000001)", "legendFormat": "rating"}]
    },
    {
      "type": "stat", "title": "Helpful feedback ratio", "id": 12,
      "gridPos": {"h": 7, "w": 6, "x": 6, "y": 29},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "targets": [{"expr": "sum(rate(llm_feedback_total{sentiment=\"positive\"}[15m])) / clamp_min(sum(rate(llm_feedback_total[15m])), 0.000000001)", "legendFormat": "helpful"}]
    },
    {
      "type": "timeseries", "title": "Safety events", "id": 13,
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 29},
      "targets": [{"expr": "sum by (stage, category, action) (rate(llm_safety_events_total[5m]))", "legendFormat": "{{stage}} {{category}} {{action}}"}]
    },
    {
      "type": "timeseries", "title": "Requests by prompt version", "id": 14,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 36},
      "targets": [{"expr": "sum by (model, prompt_version) (rate(llm_prompt_version_requests_total[5m]))", "legendFormat": "{{model}} {{prompt_version}}"}]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["llm", "observability", "prometheus"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "LLM Service Overview",
  "uid": "llm-service-overview",
  "version": 3
}
